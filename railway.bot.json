{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build:db && npm run build --workspace=@app/bot"
  },
  "deploy": {
    "preDeployCommand": "npm run release",
    "startCommand": "npm run start --workspace=@app/bot",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
