{
  "name": "@app/bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "tsc -p ../../packages/db && tsc -p ../../packages/nikke",
    "build": "tsc",
    "pretypecheck": "tsc -p ../../packages/db && tsc -p ../../packages/nikke",
    "pretest": "tsc -p ../../packages/db && tsc -p ../../packages/nikke",
    "start": "node dist/index.js",
    "register": "node dist/deploy-commands.js",
    "deploy-commands": "tsx src/deploy-commands.ts",
    "clear-guild-commands": "tsx src/clear-guild-commands.ts",
    "sync:nikke": "tsx src/scripts/sync-nikke.ts",
    "smoke:gacha": "tsx src/scripts/smoke-gacha-ingest.ts",
    "backfill:patches": "tsx src/scripts/backfill-patches.ts",
    "sync:emojis": "tsx src/scripts/sync-emojis.ts",
    "sync:install": "tsx src/scripts/sync-install.ts",
    "refresh:prydwen": "tsx src/scripts/refresh-prydwen.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@app/db": "*",
    "@app/nikke": "*",
    "chrono-node": "^2.9.1",
    "discord.js": "^14.16.3",
    "drizzle-orm": "^0.36.4",
    "node-cron": "^4.6.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
